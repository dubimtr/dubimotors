# DubiMotors environment variables
# Copy this file to `.env` for local development, or set these in your hosting provider's dashboard.

# ───── Server ─────
# Port the Node server listens on. Render sets this automatically.
PORT=8080
# Set to "production" in deployed environments.
NODE_ENV=development

# ───── OpenAI / LLM Provider ─────
# Required for: /api/agent, /api/analyze-photos, /api/mulkiya-scan, /api/price-estimate, /api/verify-listing
# When missing, AI endpoints return 503 (rest of site keeps working).
OPENAI_API_KEY=sk-...

# Optional: override the OpenAI base URL (e.g. for OpenRouter, Azure OpenAI, or a Gemini-compatible proxy).
# Leave blank to use the official OpenAI endpoint.
OPENAI_BASE_URL=

# ───── SMTP (listing verification emails) ─────
# Required for: /api/verify-listing email confirmation
# When missing, the endpoint still works but skips sending the email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ───── Future / Phase 3 (not used yet) ─────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# MAPBOX_TOKEN=
